{
  "LambdaFunctionConfigurations": [
    {
      "Id": "shopstream-validator-putobject",
      "LambdaFunctionArn": "arn:aws:lambda:us-east-1:401466721010:function:shopstream-validator",
      "Events": [
        "s3:ObjectCreated:Put",
        "s3:ObjectCreated:CompleteMultipartUpload"
      ],
      "Filter": {
        "Key": {
          "FilterRules": [
            {
              "Name": "prefix",
              "Value": "events/"
            },
            {
              "Name": "suffix",
              "Value": ".csv"
            }
          ]
        }
      }
    }
  ]
}
